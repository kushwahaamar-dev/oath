# Oath env template вЂ” copy to `web/.env.local` for local dev.
# Any value left as `PLACEHOLDER` is treated as absent; the feature
# falls back to a deterministic mock so the app runs end-to-end.

# в”Ђв”Ђ Solana в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_OATH_PROGRAM_ID=2Uvqbnt6kiaB7Y3AHhtS2FLWRFrJweRebtErSQE2kPmy

# Server-side keypairs (relative to repo root)
ORACLE_KEYPAIR_PATH=keys/oracle.json
AGENT_KEYPAIR_PATH=keys/agent.json

# в”Ђв”Ђ Gemini (structured oath proposal + next-action planning) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
GEMINI_API_KEY=PLACEHOLDER
GEMINI_MODEL=gemini-2.0-flash-exp

# в”Ђв”Ђ Google Places API (New) вЂ” recipient discovery в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
GOOGLE_PLACES_API_KEY=PLACEHOLDER

# в”Ђв”Ђ ElevenLabs вЂ” TTS narration в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
ELEVENLABS_API_KEY=PLACEHOLDER
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# в”Ђв”Ђ MongoDB Atlas вЂ” audit log, dashboards, reputation в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
MONGODB_URI=PLACEHOLDER
MONGODB_DB=oath

# в”Ђв”Ђ x402 facilitator в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
X402_FACILITATOR_URL=https://x402.coinbase.com

# в”Ђв”Ђ App origin в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
NEXT_PUBLIC_APP_URL=http://localhost:3000
